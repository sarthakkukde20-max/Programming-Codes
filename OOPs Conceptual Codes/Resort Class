import java.util.Scanner;

class Resort {
    int RNo, Days;
    String Name;
    float Charges;

    float Compute() {
        float amount = Days * Charges;
        if(amount > 11000)
            amount = 1.02f * amount;
        return amount;
    }

    void Getinfo() {
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter Room No, Name, Charges, Days");
        RNo = sc.nextInt();
        Name = sc.next();
        Charges = sc.nextFloat();
        Days = sc.nextInt();
    }

    void DispInfo() {
        System.out.println(RNo+" "+Name+" "+Charges+" "+Days+" "+Compute());
    }

    public static void main(String[] args) {
        Resort r = new Resort();
        r.Getinfo();
        r.DispInfo();
    }
}
